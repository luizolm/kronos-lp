---
import Button from "../ui/Button.astro";
---

<section class="products-section" id="produtos">
  <div class="container">
    <div class="section-header reveal">
      <div class="section-badge">Nossos Produtos</div>
      <h2 class="section-title">
        Tudo que voce precisa para <span class="gradient-text">vender mais</span>
      </h2>
      <p class="section-desc">
        Tudo o que você precisa para atrair clientes, identificar os melhores e fechar vendas — tudo integrado e turbinado por Inteligência Artificial.
      </p>
    </div>

    <div class="products-grid">
      <!-- Product 1: Agentes de IA -->
      <div class="product-card reveal reveal-delay-1">
        <div class="product-body">
          <div class="product-icon-wrapper icon-purple">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/>
            </svg>
          </div>
          <h3 class="product-title">Agentes de IA</h3>
          <p class="product-desc">
            Líderes em resposta instantânea. Nossos agentes identificam os melhores clientes em segundos, 24 horas por dia, 7 dias por semana, com comunicação humanizada.
          </p>
          <ul class="product-features-list">
            <li><span class="bullet-icon">✦</span> Resposta em &lt; 2 segundos</li>
            <li><span class="bullet-icon">✦</span> Agendamento automático de reuniões</li>
            <li><span class="bullet-icon">✦</span> Passa a conversa pro vendedor na hora certa</li>
          </ul>
        </div>
        <Button variant="filled" id="cta-comecar-produtos-agentes">COMEÇAR GRATUITAMENTE</Button>
      </div>

      <!-- Product 2: CRM Inteligente -->
      <div class="product-card reveal reveal-delay-2">
        <div class="product-body">
          <div class="product-icon-wrapper icon-cyan">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <path d="M3 9h18"/>
              <path d="M9 21V9"/>
            </svg>
          </div>
          <h3 class="product-title">CRM Inteligente</h3>
          <p class="product-desc">
            Um painel visual que se atualiza sozinho. Acompanhe cada venda e saiba onde focar para fechar mais.
          </p>
          <ul class="product-features-list">
            <li><span class="bullet-icon">✦</span> Painel visual de vendas em andamento</li>
            <li><span class="bullet-icon">✦</span> Preenchimento com IA</li>
            <li><span class="bullet-icon">✦</span> Integração com WhatsApp e Meta Ads</li>
          </ul>
        </div>
        <Button variant="filled" id="cta-comecar-produtos-crm">COMEÇAR GRATUITAMENTE</Button>
      </div>

      <!-- Product 3: Inbox Omnichannel -->
      <div class="product-card reveal reveal-delay-3">
        <div class="product-body">
          <div class="product-icon-wrapper icon-green">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
          </div>
          <h3 class="product-title">Caixa de Entrada Unificada</h3>
          <p class="product-desc">
            Centralize toda sua comunicação num só lugar. E-mails, mensagens, chamados de suporte agrupados por cliente e resolvidos em equipe.
          </p>
          <ul class="product-features-list">
            <li><span class="bullet-icon">✦</span> WhatsApp, Instagram e Site</li>
            <li><span class="bullet-icon">✦</span> E-mail centralizado</li>
            <li><span class="bullet-icon">✦</span> Histórico unificado do cliente</li>
          </ul>
        </div>
        <Button variant="filled" id="cta-comecar-produtos-inbox">COMEÇAR GRATUITAMENTE</Button>
      </div>
    </div>
  </div>
</section>

<style>
  .products-section {
    padding: 80px 0;
    position: relative;
  }

  .section-header {
    text-align: center;
    margin-bottom: 64px;
  }

  .section-badge {
    display: inline-block;
    background: var(--dark-2);
    border: 1px solid var(--dark-3);
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 2px;
    padding: 6px 16px;
    border-radius: 8px;
    margin-bottom: 20px;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 36px);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 16px;
    color: var(--text-primary);
  }

  .section-desc {
    font-family: var(--font-display);
    font-size: 16px;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .product-card {
    background: var(--dark-2);
    border: 1px solid var(--dark-3);
    border-radius: 16px;
    padding: 32px;
    transition: all 0.2s ease;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .product-body {
    flex: 1;
  }

  .product-card:hover {
    border-color: rgba(130, 87, 229, 0.3);
  }

  .product-icon-wrapper {
    width: 60px;
    height: 60px;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 32px;
  }

  .icon-purple {
    background: rgba(130, 87, 229, 0.1);
    color: #8257e5;
  }

  .icon-cyan {
    background: rgba(97, 218, 251, 0.1);
    color: #61dafb;
  }

  .icon-green {
    background: rgba(0, 179, 126, 0.1);
    color: #00b37e;
  }

  .product-title {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 16px;
  }

  .product-desc {
    font-family: var(--font-display);
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 32px;
  }

  .product-features-list {
    list-style: none;
    margin: 0 0 40px 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
    font-family: var(--font-display);
  }

  .product-features-list li {
    font-size: 14px;
    color: var(--text-muted);
  }

  .bullet-icon {
    color: #8257e5;
  }

  @media (max-width: 1024px) {
    .products-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .products-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
