---
import { getEntry } from "astro:content";

const entry = await getEntry("clients", "data");
const { companies } = entry.data;

const iconPaths: Record<string, string> = {
  scale: '<path d="M16 16l3-8 3 8c-1.3.7-3.7.7-6 0z"/><path d="M2 16l3-8 3 8c-1.3.7-3.7.7-6 0z"/><path d="M7 21h10"/><path d="M12 3v18"/><path d="M3 7h2c2 0 5-1 7-2 2 1 5 2 7 2h2"/>',
  "heart-pulse": '<path d="M19.5 12.572l-7.5 7.428-7.5-7.428A5 5 0 1 1 12 6.006a5 5 0 1 1 7.5 6.572"/><path d="M12 6l-1 4h2l3-3"/><path d="M12 6l1 4h-2l-3-3"/>',
  armchair: '<path d="M19 9V6a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v3"/><path d="M3 16a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-5a2 2 0 0 0-4 0v1.5a.5.5 0 0 1-.5.5h-9a.5.5 0 0 1-.5-.5V11a2 2 0 0 0-4 0z"/><path d="M5 18v2"/><path d="M19 18v2"/>',
  rocket: '<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="M12 15l-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>',
  calculator: '<rect width="16" height="20" x="4" y="2" rx="2"/><line x1="8" x2="16" y1="6" y2="6"/><line x1="16" x2="16" y1="14" y2="18"/><path d="M16 10h.01"/><path d="M12 10h.01"/><path d="M8 10h.01"/><path d="M12 14h.01"/><path d="M8 14h.01"/><path d="M12 18h.01"/><path d="M8 18h.01"/>',
  dumbbell: '<path d="M14.4 14.4 9.6 9.6"/><path d="M18.657 21.485a2 2 0 1 1-2.829-2.828l-1.767-1.768a2 2 0 1 1-2.829-2.829l6.364-6.364a2 2 0 1 1 2.829 2.829l1.767 1.767a2 2 0 1 1 2.829 2.829z"/><path d="m21.5 21.5-1.4-1.4"/><path d="M3.9 3.9 2.5 2.5"/><path d="M6.404 12.768a2 2 0 1 1-2.829-2.829 2 2 0 1 1-2.829-2.829l.707-.707"/>',
  "shield-check": '<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/>',
  "hard-hat": '<path d="M10 10V5a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v5"/><path d="M14 6a6 6 0 0 1 4.24 10.24"/><path d="M5.76 16.24A6 6 0 0 1 10 6"/><path d="M2 20a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-1a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2z"/>',
};
---

<!-- Logos / Social Proof Bar -->
<section class="logos-section">
  <div class="container">
    <div class="logos-header reveal">
      <span class="logos-tagline">Confiado por lideres de mercado</span>
    </div>
    <div class="logos-ticker">
      <div class="logos-track">
        {/* Render twice for infinite scroll */}
        {[...companies, ...companies].map((c) => (
          <div class:list={["logo-item", c.style]}>
            <svg class="logo-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={iconPaths[c.icon] ?? ''} />
            {c.name}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- Problem/Agitation section -->
<section class="problem-section" id="problema">
  <div class="container">
    <div class="problem-badge reveal">
      <span>O mercado mudou. Voce mudou?</span>
    </div>
    <h2 class="problem-title reveal reveal-delay-1">
      Enquanto voce usa planilha,<br/>
      <span class="gradient-text">seus concorrentes estao usando IA.</span>
    </h2>
    <p class="problem-subtitle reveal reveal-delay-2">
      Times que querem crescer nao podem perder tempo com ferramentas que nao acompanham.
    </p>

    <div class="problem-grid reveal reveal-delay-3">
      <div class="problem-card problem-bad">
        <div class="problem-card-header">
          <span class="problem-icon bad">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </span>
          <h3>Sem a Kronos</h3>
        </div>
        <ul class="problem-list bad-list">
          <li>Leads perdidos em planilhas desorganizadas</li>
          <li>Leads sem resposta = dinheiro na mesa</li>
          <li>Sem saber em que pe esta cada venda</li>
          <li>Vendedores gastando horas em tarefas manuais</li>
          <li>Sem dados para decisoes estrategicas</li>
          <li>Chegada ao fechamento sem contexto</li>
        </ul>
      </div>
      <div class="vs-divider">
        <div class="vs-circle">VS</div>
      </div>
      <div class="problem-card problem-good">
        <div class="problem-card-header">
          <span class="problem-icon good">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
          </span>
          <h3>Com a Kronos</h3>
        </div>
        <ul class="problem-list good-list">
          <li>Cada venda visivel e sob controle</li>
          <li>IA qualifica e responde leads automaticamente 24/7</li>
          <li>Metricas em tempo real para decisoes certeiras</li>
          <li>Vendedores focados so em fechar</li>
          <li>Relatorios claros que mostram o que esta funcionando</li>
          <li>Contexto completo antes de cada reuniao</li>
        </ul>
      </div>
    </div>

    <div class="problem-cta reveal">
      <a href="https://app.kronoshub.com.br/login" class="btn-cta-primary">
        QUERO SAIR DAS PLANILHAS AGORA
      </a>
    </div>
  </div>
</section>

<style>
  /* ===== LOGOS ===== */
  .logos-section {
    padding: 40px 0;
    border-top: 1px solid var(--dark-3);
    border-bottom: 1px solid var(--dark-3);
    overflow: hidden;
  }

  .logos-header {
    text-align: center;
    margin-bottom: 32px;
  }

  .logos-tagline {
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 500;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .logos-ticker {
    position: relative;
    overflow: hidden;
    mask-image: linear-gradient(90deg, transparent, black 15%, black 85%, transparent);
    -webkit-mask-image: linear-gradient(90deg, transparent, black 15%, black 85%, transparent);
  }

  .logos-track {
    display: flex;
    gap: 48px;
    width: max-content;
    animation: ticker 25s linear infinite;
  }

  @keyframes ticker {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .logo-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 400;
    color: var(--text-muted);
    white-space: nowrap;
    transition: color 0.3s;
    cursor: default;
    letter-spacing: -0.5px;
  }

  .logo-item:hover {
    color: var(--text-secondary);
  }

  .logo-icon {
    flex-shrink: 0;
    opacity: 0.7;
  }

  .logo-item:hover .logo-icon {
    opacity: 1;
  }

  /* Typography variations */
  .logo-bold-upper { font-weight: 700; text-transform: uppercase; letter-spacing: 2px; font-size: 15px; }
  .logo-light-italic { font-weight: 300; font-style: italic; }
  .logo-heavy-tight { font-weight: 800; letter-spacing: -1px; }
  .logo-mono { font-family: var(--font-body); text-transform: uppercase; font-weight: 500; font-size: 15px; letter-spacing: 1px; }
  .logo-semibold-caps { font-weight: 600; font-variant: small-caps; font-size: 20px; }
  .logo-black-upper { font-weight: 900; text-transform: uppercase; font-size: 16px; letter-spacing: 1.5px; }
  .logo-medium { font-weight: 500; }
  .logo-bold-tight { font-weight: 700; letter-spacing: -0.5px; }

  /* ===== PROBLEM ===== */
  .problem-section {
    padding: 80px 0;
  }

  .problem-badge {
    display: flex;
    justify-content: center;
    margin-bottom: 24px;
  }

  .problem-badge span {
    display: inline-flex;
    padding: 6px 16px;
    background: var(--dark-2);
    border: 1px solid var(--dark-3);
    border-radius: 8px;
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--text-primary);
  }

  .problem-title {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 36px);
    font-weight: 500;
    line-height: 1.15;
    letter-spacing: -0.02em;
    text-align: center;
    margin-bottom: 20px;
  }

  .problem-subtitle {
    text-align: center;
    font-family: var(--font-display);
    font-size: 16px;
    color: var(--text-secondary);
    margin-bottom: 60px;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.6;
  }

  .problem-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 32px;
    align-items: center;
    max-width: 1000px;
    margin: 0 auto 60px;
  }

  .problem-card {
    background: var(--dark-2);
    border: 1px solid var(--dark-3);
    border-radius: 16px;
    padding: 32px;
    height: 100%;
  }

  .problem-bad {
    border-color: rgba(239, 68, 68, 0.15);
    background: rgba(239, 68, 68, 0.03);
  }

  .problem-good {
    border-color: rgba(130, 87, 229, 0.25);
    background: rgba(130, 87, 229, 0.05);
    box-shadow: 0 0 40px rgba(130, 87, 229, 0.06);
  }

  .problem-card-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
  }

  .problem-icon {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .problem-icon.bad {
    background: rgba(239, 68, 68, 0.12);
    color: #ef4444;
  }

  .problem-icon.good {
    background: rgba(130, 87, 229, 0.12);
    color: #8257e5;
  }

  .problem-card h3 {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 500;
    color: var(--text-primary);
  }

  .problem-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .problem-list li {
    font-family: var(--font-display);
    font-size: 14px;
    color: var(--text-secondary);
    padding-left: 20px;
    position: relative;
    line-height: 1.5;
  }

  .bad-list li::before {
    content: "\2715";
    position: absolute;
    left: 0;
    color: rgba(239, 68, 68, 0.6);
    font-weight: 500;
    font-size: 12px;
  }

  .good-list li::before {
    content: "\2713";
    position: absolute;
    left: 0;
    color: #8257e5;
    font-weight: 500;
    font-size: 12px;
  }

  .vs-divider {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .vs-circle {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--dark-2);
    border: 1px solid rgba(130, 87, 229, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 500;
    color: #8257e5;
    box-shadow: 0 0 20px rgba(130, 87, 229, 0.15);
    animation: vs-pulse 3s ease-in-out infinite;
    position: relative;
    z-index: 2;
  }

  @keyframes vs-pulse {
    0%, 100% { box-shadow: 0 0 15px rgba(130, 87, 229, 0.15); border-color: rgba(130, 87, 229, 0.3); }
    50% { box-shadow: 0 0 30px rgba(130, 87, 229, 0.4); border-color: rgba(130, 87, 229, 0.5); }
  }

  .problem-cta {
    display: flex;
    justify-content: center;
  }

  .btn-cta-primary {
    display: inline-flex;
    align-items: center;
    height: 44px;
    padding: 0 28px;
    text-transform: uppercase;
    border-radius: 8px;
    background: #8257e5;
    color: #ffffff;
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
    transition: background 0.2s;
    border: none;
    cursor: pointer;
  }

  .btn-cta-primary:hover {
    background: #996dff;
  }

  @media (max-width: 768px) {
    .problem-grid {
      grid-template-columns: 1fr;
    }
    .vs-divider { display: none; }
  }
</style>
