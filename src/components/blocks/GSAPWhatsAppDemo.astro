---
import Button from "../ui/Button.astro";
---

<section class="demo-section" id="automacao">
  <div class="container">
    <div class="demo-grid">

      <!-- Text Content -->
      <div class="demo-content reveal">
        <div class="demo-badge">Automacao com IA</div>
        <h2 class="section-title">
          Seu agente de IA trabalha enquanto <span class="gradient-text">voce dorme</span>
        </h2>
        <p class="section-desc">
          Capture, responda e identifique os melhores clientes 24h por dia, 7 dias por semana. Tudo integrado ao seu painel de vendas.
        </p>

        <ul class="benefits-list">
          <li>
            <div class="benefit-icon icon-purple">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </div>
            <div class="benefit-text">
              <strong>Qualificacao em Tempo Real</strong>
              <span>A IA analisa o contexto e define a prioridade do cliente.</span>
            </div>
          </li>
          <li>
            <div class="benefit-icon icon-cyan">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
            </div>
            <div class="benefit-text">
              <strong>Agendamento Automatico</strong>
              <span>Marcacao direta na agenda do vendedor sem intervencao humana.</span>
            </div>
          </li>
          <li>
            <div class="benefit-icon icon-green">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
            </div>
            <div class="benefit-text">
              <strong>Passagem Inteligente</strong>
              <span>Passa pro vendedor com todo o resumo da conversa.</span>
            </div>
          </li>
        </ul>

        <Button variant="outline-purple">COMECAR GRATUITAMENTE</Button>
      </div>

      <!-- Phone Mockup -->
      <div class="demo-visual reveal reveal-delay-2">
        <div class="wa-phone">
          <div class="wa-notch"></div>
          <!-- Status bar -->
          <div class="wa-statusbar">
            <span class="wa-statusbar-time">09:41</span>
            <div class="wa-statusbar-icons">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><rect x="1" y="14" width="4" height="8" rx="1"/><rect x="7" y="10" width="4" height="12" rx="1"/><rect x="13" y="6" width="4" height="16" rx="1"/><rect x="19" y="2" width="4" height="20" rx="1"/></svg>
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.55a11 11 0 0 1 14.08 0"/><path d="M1.42 9a16 16 0 0 1 21.16 0"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><circle cx="12" cy="20" r="1" fill="currentColor"/></svg>
              <svg width="14" height="8" viewBox="0 0 28 14" fill="currentColor"><rect x="0" y="0" width="24" height="14" rx="3" fill="none" stroke="currentColor" stroke-width="1.5"/><rect x="2.5" y="2.5" width="19" height="9" rx="1.5"/><rect x="25" y="4" width="3" height="6" rx="1"/></svg>
            </div>
          </div>
          <!-- Header -->
          <div class="wa-header">
            <div class="wa-header-back">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
            </div>
            <div class="wa-header-avatar">K</div>
            <div class="wa-header-info">
              <span class="wa-header-name">Kronos IA</span>
              <span class="wa-header-status">online</span>
            </div>
            <div class="wa-header-icons">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="1"></circle><circle cx="12" cy="5" r="1"></circle><circle cx="12" cy="19" r="1"></circle></svg>
            </div>
          </div>
          <!-- Chat area -->
          <div class="wa-chat" id="chatContainer">
            <!-- Messages inserted by JS -->
          </div>
          <!-- Input bar -->
          <div class="wa-inputbar">
            <div class="wa-input-emoji">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
            </div>
            <div class="wa-input-field">Mensagem</div>
            <div class="wa-input-actions">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
            </div>
            <div class="wa-input-mic">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style is:global>
  /* ========== Section layout ========== */
  .demo-section {
    padding: 80px 0;
    position: relative;
    overflow: hidden;
  }

  .demo-grid {
    display: flex;
    align-items: center;
    gap: 80px;
    position: relative;
    z-index: 1;
  }

  .demo-content {
    flex: 1;
  }

  .demo-badge {
    display: inline-block;
    padding: 6px 16px;
    background: var(--dark-2);
    border: 1px solid var(--dark-3);
    border-radius: 8px;
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 20px;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 36px);
    font-weight: 500;
    line-height: 1.1;
    margin-bottom: 16px;
    color: var(--text-primary);
    letter-spacing: -0.02em;
  }

  .section-desc {
    font-family: var(--font-display);
    font-size: 16px;
    line-height: 1.6;
    color: var(--text-secondary);
    margin-bottom: 48px;
    max-width: 480px;
  }

  .benefits-list {
    list-style: none;
    margin: 0 0 48px 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 24px;
    font-family: var(--font-display);
  }

  .benefits-list li {
    display: flex;
    gap: 16px;
  }

  .benefit-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .icon-purple { background: rgba(130, 87, 229, 0.1); color: #8257e5; }
  .icon-cyan { background: rgba(97, 218, 251, 0.1); color: #61dafb; }
  .icon-green { background: rgba(0, 179, 126, 0.1); color: #00b37e; }

  .benefit-text {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .benefit-text strong {
    font-size: 16px;
    font-weight: 600;
    color: var(--text-primary);
  }

  .benefit-text span {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .demo-visual {
    flex: 1;
    display: flex;
    justify-content: center;
    perspective: 1000px;
  }

  /* ========== WhatsApp Phone — Kronos colors ========== */
  .wa-phone {
    width: 320px;
    height: 640px;
    background: #09090b;
    border-radius: 40px;
    border: 6px solid #27272a;
    box-shadow:
      0 0 0 2px #18181b,
      0 30px 60px rgba(0,0,0,0.6);
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transform: rotateY(-10deg) rotateX(5deg);
    transition: transform 0.5s ease;
  }

  .wa-phone:hover {
    transform: rotateY(0deg) rotateX(0deg);
  }

  /* Notch */
  .wa-notch {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100px;
    height: 18px;
    background: #000000;
    border-bottom-left-radius: 12px;
    border-bottom-right-radius: 12px;
    z-index: 20;
  }

  /* Status bar */
  .wa-statusbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 4px 16px 2px;
    font-size: 10px;
    font-weight: 400;
    color: #e9edef;
    background: #18181b;
    z-index: 5;
    height: 20px;
  }

  .wa-statusbar-icons {
    display: flex;
    align-items: center;
    gap: 4px;
    color: #e9edef;
  }

  .wa-statusbar-icons svg {
    width: 10px;
    height: 10px;
  }

  /* Header */
  .wa-header {
    background: #18181b;
    padding: 8px 10px 10px;
    display: flex;
    align-items: center;
    gap: 8px;
    z-index: 5;
    border-bottom: 1px solid #27272a;
  }

  .wa-header-back {
    color: #8257e5;
    display: flex;
    flex-shrink: 0;
  }

  .wa-header-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #8257e5;
    color: #ffffff;
    font-family: var(--font-display);
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 15px;
    flex-shrink: 0;
  }

  .wa-header-info {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-width: 0;
  }

  .wa-header-name {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 600;
    color: #e9edef;
    line-height: 1.2;
  }

  .wa-header-status {
    font-family: var(--font-display);
    font-size: 11px;
    color: #00b37e;
    line-height: 1.2;
  }

  .wa-header-icons {
    display: flex;
    gap: 16px;
    color: #a1a1aa;
    flex-shrink: 0;
  }

  /* Chat area */
  .wa-chat {
    flex: 1;
    background: #09090b;
    padding: 12px 10px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    overflow-y: auto;
    scroll-behavior: smooth;
  }

  .wa-chat::-webkit-scrollbar {
    width: 4px;
  }
  .wa-chat::-webkit-scrollbar-thumb {
    background: rgba(161,161,170,0.2);
    border-radius: 2px;
  }

  /* Message bubbles */
  .wa-bubble {
    max-width: 85%;
    padding: 8px 10px 6px;
    font-family: var(--font-display);
    font-size: 12.5px;
    line-height: 1.4;
    position: relative;
    opacity: 0;
    transform: translateY(8px);
    animation: waFadeIn 0.3s ease forwards;
    word-wrap: break-word;
  }

  @keyframes waFadeIn {
    to { opacity: 1; transform: translateY(0); }
  }

  /* Outgoing (user) — Kronos purple */
  .wa-bubble.outgoing {
    align-self: flex-end;
    background: #8257e5;
    color: #ffffff;
    border-radius: 12px 12px 4px 12px;
    margin-left: 30px;
  }

  .wa-bubble.outgoing.has-tail {
    margin-right: 8px;
  }
  .wa-bubble.outgoing.has-tail::after {
    content: '';
    position: absolute;
    right: -7px;
    bottom: 0;
    width: 0;
    height: 0;
    border-style: solid;
    border-width: 0 0 10px 8px;
    border-color: transparent transparent #8257e5 transparent;
  }

  /* Incoming (bot) — dark shape */
  .wa-bubble.incoming {
    align-self: flex-start;
    background: #27272a;
    color: #e9edef;
    border-radius: 12px 12px 12px 4px;
    margin-right: 30px;
  }

  .wa-bubble.incoming.has-tail {
    margin-left: 8px;
  }
  .wa-bubble.incoming.has-tail::after {
    content: '';
    position: absolute;
    left: -7px;
    bottom: 0;
    width: 0;
    height: 0;
    border-style: solid;
    border-width: 0 8px 10px 0;
    border-color: transparent #27272a transparent transparent;
  }

  /* Message text */
  .wa-bubble-text {
    display: inline;
  }

  /* Time + check row */
  .wa-bubble-meta {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 3px;
    margin-top: 3px;
    float: right;
    margin-left: 8px;
    position: relative;
    top: 3px;
  }

  .wa-bubble-time {
    font-family: var(--font-display);
    font-size: 10px;
    color: rgba(255, 255, 255, 0.45);
    white-space: nowrap;
  }

  /* Double check (read receipt) */
  .wa-check {
    display: inline-flex;
  }
  .wa-check svg {
    color: #53bdeb;
  }

  /* CRM card — system notification style */
  .wa-system-card {
    align-self: center;
    background: rgba(97, 218, 251, 0.08);
    border: 1px dashed rgba(97, 218, 251, 0.25);
    border-radius: 8px;
    padding: 6px 14px;
    font-family: var(--font-display);
    font-size: 10px;
    color: #61dafb;
    text-align: center;
    margin: 6px 0;
    opacity: 0;
    transform: translateY(8px);
    animation: waFadeIn 0.3s ease forwards;
  }

  /* Typing indicator */
  .wa-typing {
    align-self: flex-start;
    background: #27272a;
    border-radius: 12px 12px 12px 4px;
    padding: 12px 16px;
    display: flex;
    gap: 4px;
    align-items: center;
    margin-left: 8px;
    margin-right: 30px;
    opacity: 0;
    transform: translateY(8px);
    animation: waFadeIn 0.25s ease forwards;
  }

  .wa-typing::after {
    content: '';
    position: absolute;
    left: -7px;
    bottom: 0;
    width: 0;
    height: 0;
    border-style: solid;
    border-width: 0 8px 10px 0;
    border-color: transparent #27272a transparent transparent;
  }

  .wa-typing span {
    width: 6px;
    height: 6px;
    background: #a1a1aa;
    border-radius: 50%;
    animation: waTypingBounce 1.4s infinite;
  }

  .wa-typing span:nth-child(2) { animation-delay: 0.2s; }
  .wa-typing span:nth-child(3) { animation-delay: 0.4s; }

  @keyframes waTypingBounce {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
    30% { transform: translateY(-5px); opacity: 1; }
  }

  /* Input bar */
  .wa-inputbar {
    background: #18181b;
    padding: 4px 6px 14px;
    display: flex;
    align-items: center;
    gap: 4px;
    border-top: 1px solid #27272a;
  }

  .wa-input-emoji {
    color: #a1a1aa;
    display: flex;
    flex-shrink: 0;
    padding: 2px;
  }

  .wa-input-emoji svg {
    width: 18px;
    height: 18px;
  }

  .wa-input-field {
    flex: 1;
    background: #27272a;
    border: none;
    border-radius: 16px;
    padding: 5px 12px;
    font-family: var(--font-display);
    font-size: 11px;
    color: #71717a;
  }

  .wa-input-actions {
    display: flex;
    gap: 4px;
    color: #a1a1aa;
    flex-shrink: 0;
  }

  .wa-input-actions svg {
    width: 16px;
    height: 16px;
  }

  .wa-input-mic {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: #8257e5;
    color: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .wa-input-mic svg {
    width: 14px;
    height: 14px;
  }

  @media (max-width: 900px) {
    .demo-grid {
      flex-direction: column;
    }
    .demo-visual {
      margin-top: 40px;
    }
    .wa-phone {
      transform: none;
    }
  }
</style>

<script>
  const messages = [
    { type: 'user', text: 'Oi, quero agendar uma consulta com a Dra. Marina. Tem horario essa semana?', time: '09:41' },
    { type: 'bot', text: 'Ola! Claro. A Dra. Marina tem disponibilidade quinta-feira as 10h ou sexta as 15h. Qual prefere?', time: '09:41' },
    { type: 'user', text: 'Quinta as 10h fica perfeito!', time: '09:42' },
    { type: 'bot', text: 'Otimo! Consulta agendada para quinta, 10h com a Dra. Marina. Vou enviar a confirmacao e o lembrete por aqui, ok?', time: '09:42' },
    { type: 'crm', text: 'Consulta agendada: Dra. Marina - Qui 10h', time: '' },
    { type: 'user', text: 'Perfeito, obrigada!', time: '09:43' },
    { type: 'bot', text: 'Por nada! Qualquer duvida e so chamar. Ate quinta!', time: '09:43' }
  ];

  const CHECK_SVG = '<svg width="16" height="11" viewBox="0 0 16 11" fill="none"><path d="M11.071 0.929L4.5 7.5L1.429 4.429" stroke="#53bdeb" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/><path d="M14.571 0.929L8 7.5L6.786 6.286" stroke="#53bdeb" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>';

  let lastType = '';

  function createBubble(msg) {
    if (msg.type === 'crm') {
      const card = document.createElement('div');
      card.className = 'wa-system-card';
      card.innerText = msg.text;
      lastType = 'crm';
      return card;
    }

    const bubble = document.createElement('div');
    const isUser = msg.type === 'user';
    const hasTail = lastType !== msg.type;
    bubble.className = `wa-bubble ${isUser ? 'outgoing' : 'incoming'}${hasTail ? ' has-tail' : ''}`;

    const textSpan = document.createElement('span');
    textSpan.className = 'wa-bubble-text';
    textSpan.innerText = msg.text;

    const meta = document.createElement('span');
    meta.className = 'wa-bubble-meta';

    const timeSpan = document.createElement('span');
    timeSpan.className = 'wa-bubble-time';
    timeSpan.textContent = msg.time;
    meta.appendChild(timeSpan);

    if (isUser) {
      const checkSpan = document.createElement('span');
      checkSpan.className = 'wa-check';
      checkSpan.innerHTML = CHECK_SVG;
      meta.appendChild(checkSpan);
    }

    bubble.appendChild(textSpan);
    bubble.appendChild(meta);

    lastType = msg.type;
    return bubble;
  }

  function showTyping(container) {
    const typing = document.createElement('div');
    typing.className = 'wa-typing';
    typing.style.position = 'relative';
    typing.innerHTML = '<span></span><span></span><span></span>';
    container.appendChild(typing);
    container.scrollTop = container.scrollHeight;
    return typing;
  }

  function runChatSequence() {
    const container = document.getElementById('chatContainer');
    if (!container) return;
    container.innerHTML = '';
    lastType = '';

    let delay = 800;
    let totalDelay = 0;

    messages.forEach((msg) => {
      if (msg.type === 'bot') {
        const typingDelay = delay;
        setTimeout(() => {
          showTyping(container);
        }, typingDelay);

        delay += 1500;

        const msgDelay = delay;
        setTimeout(() => {
          const typingEl = container.querySelector('.wa-typing');
          if (typingEl) typingEl.remove();
          container.appendChild(createBubble(msg));
          container.scrollTop = container.scrollHeight;
        }, msgDelay);

        delay += 2000;
      } else if (msg.type === 'crm') {
        const d = delay;
        setTimeout(() => {
          container.appendChild(createBubble(msg));
          container.scrollTop = container.scrollHeight;
        }, d);

        delay += 1000;
      } else {
        const d = delay;
        setTimeout(() => {
          container.appendChild(createBubble(msg));
          container.scrollTop = container.scrollHeight;
        }, d);

        delay += 1500;
      }

      totalDelay = delay;
    });

    setTimeout(() => runChatSequence(), totalDelay + 5000);
  }

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        runChatSequence();
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.5 });

  const demoSection = document.querySelector('.demo-section');
  if (demoSection) observer.observe(demoSection);
</script>
