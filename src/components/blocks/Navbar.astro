---
import logoSvg from "../../assets/logo.svg";
import Button from "../ui/Button.astro";
---

<header class="navbar" id="navbar">
  <div class="nav-container">
    <!-- Logo -->
    <a href="/" class="nav-logo">
      <img src={logoSvg.src} alt="Kronos Logo" class="logo-img" />
      <span class="logo-text">KRONOS</span>
    </a>

    <!-- Desktop Navigation -->
    <nav class="nav-desktop">
      <!-- Produtos Dropdown -->
      <div class="nav-dropdown">
        <button class="nav-trigger" type="button">
          Produtos
          <svg class="chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </button>
        <div class="dropdown-content dropdown-products">
          <ul class="dropdown-grid">
            <li>
              <a href="#produtos" class="dropdown-item">
                <div class="dropdown-item-header">
                  <!-- BarChart3 icon -->
                  <svg class="dropdown-icon icon-purple" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="20" x2="12" y2="10"></line><line x1="18" y1="20" x2="18" y2="4"></line><line x1="6" y1="20" x2="6" y2="16"></line></svg>
                  <span class="dropdown-item-title">Kronos CRM</span>
                </div>
                <p class="dropdown-item-desc">Painel de vendas, contatos e resultados em tempo real.</p>
              </a>
            </li>
            <li>
              <a href="#produtos" class="dropdown-item">
                <div class="dropdown-item-header">
                  <!-- Bot icon -->
                  <svg class="dropdown-icon icon-green" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"></path><rect width="16" height="12" x="4" y="8" rx="2"></rect><path d="M2 14h2"></path><path d="M20 14h2"></path><path d="M15 13v2"></path><path d="M9 13v2"></path></svg>
                  <span class="dropdown-item-title">Kronos Agents</span>
                </div>
                <p class="dropdown-item-desc">Assistentes de IA que identificam clientes e agendam reunioes.</p>
              </a>
            </li>
            <li>
              <a href="#produtos" class="dropdown-item">
                <div class="dropdown-item-header">
                  <!-- Inbox icon -->
                  <svg class="dropdown-icon icon-cyan" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 16 12 14 15 10 15 8 12 2 12"></polyline><path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"></path></svg>
                  <span class="dropdown-item-title">Kronos Inbox</span>
                </div>
                <p class="dropdown-item-desc">Centralize WhatsApp, Instagram e e-mail em uma caixa.</p>
              </a>
            </li>
          </ul>
        </div>
      </div>

      <!-- Recursos Dropdown -->
      <div class="nav-dropdown">
        <button class="nav-trigger" type="button">
          Recursos
          <svg class="chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </button>
        <div class="dropdown-content dropdown-resources">
          <ul class="dropdown-list">
            <li>
              <a href="#automacao" class="dropdown-item">
                <div class="dropdown-item-header">
                  <!-- Calendar icon -->
                  <svg class="dropdown-icon icon-purple" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></rect></svg>
                  <span class="dropdown-item-title">Agendamento Automatico</span>
                </div>
                <p class="dropdown-item-desc">Seus leads agendam direto na agenda do vendedor via IA.</p>
              </a>
            </li>
            <li>
              <a href="#automacao" class="dropdown-item">
                <div class="dropdown-item-header">
                  <!-- Sparkles icon -->
                  <svg class="dropdown-icon icon-green" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"></path><path d="M5 3v4"></path><path d="M19 17v4"></path><path d="M3 5h4"></path><path d="M17 19h4"></path></svg>
                  <span class="dropdown-item-title">CRM com IA</span>
                </div>
                <p class="dropdown-item-desc">Atualizacao automatica de pipeline, notas e status com IA.</p>
              </a>
            </li>
            <li>
              <a href="#automacao" class="dropdown-item">
                <div class="dropdown-item-header">
                  <!-- UserPlus icon -->
                  <svg class="dropdown-icon icon-cyan" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><line x1="19" y1="8" x2="19" y2="14"></line><line x1="22" y1="11" x2="16" y2="11"></line></svg>
                  <span class="dropdown-item-title">Criacao Automatica</span>
                </div>
                <p class="dropdown-item-desc">Contatos e negociacoes criados automaticamente a partir das conversas.</p>
              </a>
            </li>
          </ul>
        </div>
      </div>

      <!-- Precos Link -->
      <a href="#precos" class="nav-trigger nav-link-direct">Precos</a>
    </nav>

    <!-- Desktop Actions -->
    <div class="nav-actions">
      <div class="actions-divider"></div>
      <a href="https://app.kronoshub.com.br" class="btn-nav-ghost">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
        Login
      </a>
      <Button variant="outline-purple">COMECAR GRATUITAMENTE</Button>
      <button class="theme-toggle" id="themeToggle" type="button" aria-label="Alternar tema">
        <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
        <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
      </button>
    </div>

    <!-- Mobile Toggle -->
    <button class="mobile-toggle" id="mobileToggle" type="button" aria-label="Menu">
      <svg class="menu-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="12" x2="20" y2="12"></line><line x1="4" y1="6" x2="20" y2="6"></line><line x1="4" y1="18" x2="20" y2="18"></line></svg>
      <svg class="close-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>
  </div>
</header>

<!-- Mobile Menu Overlay -->
<div class="mobile-overlay" id="mobileOverlay">
  <nav class="mobile-nav">
    <!-- Produtos -->
    <div class="mobile-section">
      <span class="mobile-section-label">Produtos</span>
      <a href="#produtos" class="mobile-item">
        <svg class="mobile-item-icon icon-purple" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="20" x2="12" y2="10"></line><line x1="18" y1="20" x2="18" y2="4"></line><line x1="6" y1="20" x2="6" y2="16"></line></svg>
        <span>Kronos CRM</span>
      </a>
      <a href="#produtos" class="mobile-item">
        <svg class="mobile-item-icon icon-green" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"></path><rect width="16" height="12" x="4" y="8" rx="2"></rect><path d="M2 14h2"></path><path d="M20 14h2"></path><path d="M15 13v2"></path><path d="M9 13v2"></path></svg>
        <span>Kronos Agents</span>
      </a>
      <a href="#produtos" class="mobile-item">
        <svg class="mobile-item-icon icon-cyan" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 16 12 14 15 10 15 8 12 2 12"></polyline><path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"></path></svg>
        <span>Kronos Inbox</span>
      </a>
    </div>

    <!-- Recursos -->
    <div class="mobile-section">
      <span class="mobile-section-label">Recursos</span>
      <a href="#automacao" class="mobile-item">
        <svg class="mobile-item-icon icon-purple" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
        <span>Agendamento Automatico</span>
      </a>
      <a href="#automacao" class="mobile-item">
        <svg class="mobile-item-icon icon-green" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"></path><path d="M5 3v4"></path><path d="M19 17v4"></path><path d="M3 5h4"></path><path d="M17 19h4"></path></svg>
        <span>CRM com IA</span>
      </a>
      <a href="#automacao" class="mobile-item">
        <svg class="mobile-item-icon icon-cyan" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><line x1="19" y1="8" x2="19" y2="14"></line><line x1="22" y1="11" x2="16" y2="11"></line></svg>
        <span>Criacao Automatica</span>
      </a>
    </div>

    <!-- Precos -->
    <a href="#precos" class="mobile-item mobile-item-standalone">Precos</a>

    <!-- Theme Toggle (mobile) -->
    <div class="mobile-theme-toggle-wrapper">
      <button class="theme-toggle mobile-theme-toggle" type="button" aria-label="Alternar tema">
        <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
        <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
        <span class="mobile-theme-label">Alternar tema</span>
      </button>
    </div>

    <!-- CTAs -->
    <div class="mobile-ctas">
      <a href="https://app.kronoshub.com.br" class="mobile-btn-outline">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
        Login
      </a>
      <Button variant="filled">COMECAR GRATUITAMENTE</Button>
    </div>
  </nav>
</div>

<style>
  /* ── Header ──────────────────────────────────────────────── */
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: var(--navbar-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 2px solid var(--border-subtle);
  }

  .nav-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }

  /* ── Logo ─────────────────────────────────────────────────── */
  .nav-logo {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-img {
    height: 24px;
    width: auto;
    object-fit: contain;
  }

  .logo-text {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.02em;
  }

  /* ── Desktop Nav ─────────────────────────────────────────── */
  .nav-desktop {
    display: none;
    align-items: center;
    gap: 4px;
  }

  @media (min-width: 769px) {
    .nav-desktop {
      display: flex;
    }
  }

  .nav-trigger {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: var(--text-muted);
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 500;
    padding: 8px 12px;
    border-radius: 6px;
    border: none;
    background: none;
    cursor: pointer;
    transition: color 0.2s, background 0.2s;
    text-decoration: none;
    white-space: nowrap;
  }

  .nav-trigger:hover {
    color: var(--text-primary);
    background: var(--overlay-bg);
  }

  .chevron {
    transition: transform 0.2s;
    opacity: 0.5;
  }

  /* ── Dropdown ────────────────────────────────────────────── */
  .nav-dropdown {
    position: relative;
  }

  .dropdown-content {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(8px);
    background: var(--dark-2);
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    padding: 12px;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s, visibility 0.2s, transform 0.2s;
    transform-origin: top center;
    box-shadow: 0 16px 48px var(--shadow-color);
  }

  .nav-dropdown:hover .dropdown-content,
  .nav-dropdown:focus-within .dropdown-content {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(4px);
  }

  .nav-dropdown:hover .chevron {
    transform: rotate(180deg);
  }

  .dropdown-products {
    width: 520px;
  }

  .dropdown-resources {
    width: 360px;
  }

  .dropdown-grid {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4px;
  }

  .dropdown-grid li:last-child {
    grid-column: span 2;
  }

  .dropdown-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .dropdown-item {
    display: block;
    padding: 12px;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.15s;
  }

  .dropdown-item:hover {
    background: var(--overlay-bg);
  }

  .dropdown-item-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 4px;
  }

  .dropdown-item-title {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 500;
    color: var(--text-primary);
    line-height: 1;
  }

  .dropdown-item-desc {
    font-family: var(--font-display);
    font-size: 12px;
    line-height: 1.5;
    color: var(--text-muted);
    margin: 0;
  }

  .dropdown-icon {
    flex-shrink: 0;
  }

  .icon-purple { color: #8257e5; }
  .icon-green  { color: #00b37e; }
  .icon-cyan   { color: #61dafb; }
  .icon-muted  { color: var(--text-muted); }

  /* ── Desktop Actions ─────────────────────────────────────── */
  .nav-actions {
    display: none;
    align-items: center;
    gap: 16px;
    flex-shrink: 0;
  }

  @media (min-width: 769px) {
    .nav-actions {
      display: flex;
    }
  }

  .actions-divider {
    width: 1px;
    height: 24px;
    background: var(--border-subtle);
  }

  .btn-nav-ghost {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--text-primary);
    text-decoration: none;
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 500;
    padding: 8px 12px;
    border-radius: 6px;
    transition: background 0.2s;
  }

  .btn-nav-ghost:hover {
    background: var(--overlay-bg-hover);
  }

  .btn-nav-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--text-primary);
    text-decoration: none;
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 700;
    padding: 0 28px;
    height: 44px;
    border-radius: 8px;
    border: 1px solid #8257e5;
    background: transparent;
    transition: background 0.2s ease;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  .btn-nav-cta:hover {
    background: #8257e5;
    color: #ffffff;
  }

  /* ── Theme Toggle ──────────────────────────────────────── */
  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    border: 1px solid var(--border-subtle);
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .theme-toggle:hover {
    background: var(--overlay-bg);
    color: var(--text-primary);
  }

  /* Show sun in dark mode, moon in light mode */
  .icon-sun { display: none; }
  .icon-moon { display: block; }

  [data-theme="light"] .icon-sun { display: block; }
  [data-theme="light"] .icon-moon { display: none; }

  /* ── Mobile Toggle ───────────────────────────────────────── */
  .mobile-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: var(--text-primary);
    cursor: pointer;
    padding: 4px;
  }

  @media (min-width: 769px) {
    .mobile-toggle {
      display: none;
    }
  }

  .close-icon {
    display: none;
  }

  .mobile-toggle.active .menu-icon {
    display: none;
  }

  .mobile-toggle.active .close-icon {
    display: block;
  }

  /* ── Mobile Overlay ──────────────────────────────────────── */
  .mobile-overlay {
    position: fixed;
    inset: 0;
    top: 64px;
    z-index: 999;
    background: var(--dark);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s;
  }

  .mobile-overlay.open {
    opacity: 1;
    pointer-events: auto;
  }

  @media (min-width: 769px) {
    .mobile-overlay {
      display: none;
    }
  }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 24px;
    overflow-y: auto;
    max-height: calc(100vh - 64px);
  }

  .mobile-section {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .mobile-section-label {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    padding: 0 16px;
    margin-bottom: 4px;
  }

  .mobile-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    border-radius: 8px;
    text-decoration: none;
    color: var(--text-secondary);
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 500;
    transition: color 0.2s, background 0.2s;
  }

  .mobile-item:hover {
    color: var(--text-primary);
    background: var(--overlay-bg);
  }

  .mobile-item-standalone {
    margin-top: 16px;
    font-size: 17px;
    font-weight: 500;
  }

  .mobile-item-icon {
    flex-shrink: 0;
    color: var(--text-muted);
  }

  .mobile-item-icon.icon-purple { color: #8257e5; }
  .mobile-item-icon.icon-green  { color: #00b37e; }
  .mobile-item-icon.icon-cyan   { color: #61dafb; }

  /* ── Mobile CTAs ─────────────────────────────────────────── */
  .mobile-theme-toggle-wrapper {
    margin-top: 16px;
    padding: 0 16px;
  }

  .mobile-theme-toggle {
    width: 100%;
    gap: 8px;
    padding: 12px 16px;
    border-radius: 8px;
  }

  .mobile-theme-label {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 500;
  }

  .mobile-ctas {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: 24px;
    padding-top: 24px;
    border-top: 1px solid var(--border-subtle);
  }

  .mobile-btn-outline {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 12px;
    text-transform: uppercase;
    border-radius: 8px;
    border: 1px solid var(--border-subtle);
    background: transparent;
    color: var(--text-primary);
    text-decoration: none;
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 500;
    transition: background 0.2s;
  }

  .mobile-btn-outline:hover {
    background: var(--overlay-bg);
  }

  .mobile-btn-primary {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 12px;
    text-transform: uppercase;
    border-radius: 8px;
    background: #8257e5;
    color: #ffffff;
    text-decoration: none;
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 700;
    transition: background 0.2s;
  }

  .mobile-btn-primary:hover {
    background: #996dff;
  }
</style>

<script>
  const mobileToggle = document.getElementById('mobileToggle');
  const mobileOverlay = document.getElementById('mobileOverlay');

  mobileToggle?.addEventListener('click', () => {
    mobileToggle.classList.toggle('active');
    mobileOverlay?.classList.toggle('open');
    document.body.style.overflow = mobileOverlay?.classList.contains('open') ? 'hidden' : '';
  });

  // Close mobile menu on link click
  mobileOverlay?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileToggle?.classList.remove('active');
      mobileOverlay?.classList.remove('open');
      document.body.style.overflow = '';
    });
  });

  // Theme toggle
  function toggleTheme() {
    const current = document.documentElement.getAttribute('data-theme');
    const next = current === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
  }

  document.querySelectorAll('.theme-toggle').forEach(btn => {
    btn.addEventListener('click', toggleTheme);
  });

  // React to system preference changes
  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
    if (!localStorage.getItem('theme')) {
      document.documentElement.setAttribute('data-theme', e.matches ? 'dark' : 'light');
    }
  });
</script>
